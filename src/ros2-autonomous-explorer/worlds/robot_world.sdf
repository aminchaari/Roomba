<?xml version="1.0" ?>
<sdf version="1.8">
  <world name="default">
    <plugin filename="gz-sim-physics-system" name="gz::sim::systems::Physics"></plugin>
    <plugin filename="gz-sim-scene-broadcaster-system" name="gz::sim::systems::SceneBroadcaster"></plugin>
    <plugin filename="gz-sim-sensors-system" name="gz::sim::systems::Sensors">
      <render_engine>ogre2</render_engine>
    </plugin>
    <plugin filename="gz-sim-contact-system" name="gz::sim::systems::Contact"></plugin>

    <scene>
      <ambient>0.4 0.4 0.4 1</ambient>
      <background>0.7 0.7 0.7 1</background>
      <shadows>0</shadows>
    </scene>
    <light name="sun" type="directional">
      <cast_shadows>1</cast_shadows>
      <pose>0 0 10 0 0 0</pose>
      <diffuse>0.8 0.8 0.8 1</diffuse>
      <specular>0.2 0.2 0.2 1</specular>
      <direction>0.5 0.1 -0.9</direction>
    </light>

    <gui fullscreen="0">
      <camera name="user_camera">
        <pose>0 0 24 0 1.56 3.14</pose>
      </camera>
    </gui>

    <model name="ground_plane">
      <static>true</static>
      <link name="link">
        <collision name="collision"><geometry><plane><normal>0 0 1</normal><size>100 100</size></plane></geometry></collision>
        <visual name="visual">
          <geometry><plane><normal>0 0 1</normal><size>100 100</size></plane></geometry>
          <material><ambient>0.8 0.8 0.8 1</ambient><diffuse>0.8 0.8 0.8 1</diffuse></material>
        </visual>
      </link>
    </model>

    <!-- 20x15m apartment centered at origin -->
    <model name="maze">
      <static>true</static>
      <link name="walls">
        <!-- Outer walls -->
        <visual name="b_bot"><pose>0 -7.5 0.5 0 0 0</pose><geometry><box><size>20 0.2 1</size></box></geometry><material><ambient>1 0 0 1</ambient><diffuse>1 0 0 1</diffuse></material></visual>
        <collision name="c_bot"><pose>0 -7.5 0.5 0 0 0</pose><geometry><box><size>20 0.2 1</size></box></geometry></collision>
        <visual name="b_top"><pose>0 7.5 0.5 0 0 0</pose><geometry><box><size>20 0.2 1</size></box></geometry><material><ambient>1 0 0 1</ambient><diffuse>1 0 0 1</diffuse></material></visual>
        <collision name="c_top"><pose>0 7.5 0.5 0 0 0</pose><geometry><box><size>20 0.2 1</size></box></geometry></collision>
        <visual name="b_lft"><pose>-10 0 0.5 0 0 0</pose><geometry><box><size>0.2 15 1</size></box></geometry><material><ambient>1 0 0 1</ambient><diffuse>1 0 0 1</diffuse></material></visual>
        <collision name="c_lft"><pose>-10 0 0.5 0 0 0</pose><geometry><box><size>0.2 15 1</size></box></geometry></collision>
        <visual name="b_rgt"><pose>10 0 0.5 0 0 0</pose><geometry><box><size>0.2 15 1</size></box></geometry><material><ambient>1 0 0 1</ambient><diffuse>1 0 0 1</diffuse></material></visual>
        <collision name="c_rgt"><pose>10 0 0.5 0 0 0</pose><geometry><box><size>0.2 15 1</size></box></geometry></collision>

        <!-- Horizontal wall at y=0.5: separates top rooms from bottom -->
        <visual name="wh1"><pose>-8.875 0.5 0.5 0 0 0</pose><geometry><box><size>2.25 0.2 1</size></box></geometry><material><ambient>1 0 0 1</ambient><diffuse>1 0 0 1</diffuse></material></visual>
        <collision name="cwh1"><pose>-8.875 0.5 0.5 0 0 0</pose><geometry><box><size>2.25 0.2 1</size></box></geometry></collision>
        <!-- Door gap (bedroom1 door) -->
        <visual name="wh2"><pose>-4 0.5 0.5 0 0 0</pose><geometry><box><size>4.5 0.2 1</size></box></geometry><material><ambient>1 0 0 1</ambient><diffuse>1 0 0 1</diffuse></material></visual>
        <collision name="cwh2"><pose>-4 0.5 0.5 0 0 0</pose><geometry><box><size>4.5 0.2 1</size></box></geometry></collision>
        <!-- Door gap (bedroom2 door) -->
        <visual name="wh3"><pose>1.5 0.5 0.5 0 0 0</pose><geometry><box><size>3.5 0.2 1</size></box></geometry><material><ambient>1 0 0 1</ambient><diffuse>1 0 0 1</diffuse></material></visual>
        <collision name="cwh3"><pose>1.5 0.5 0.5 0 0 0</pose><geometry><box><size>3.5 0.2 1</size></box></geometry></collision>
        <!-- Door gap (kitchen door) -->
        <visual name="wh4"><pose>7.375 0.5 0.5 0 0 0</pose><geometry><box><size>5.25 0.2 1</size></box></geometry><material><ambient>1 0 0 1</ambient><diffuse>1 0 0 1</diffuse></material></visual>
        <collision name="cwh4"><pose>7.375 0.5 0.5 0 0 0</pose><geometry><box><size>5.25 0.2 1</size></box></geometry></collision>

        <!-- Vertical wall at x=-4: bedroom1 | bedroom2 -->
        <visual name="wv1a"><pose>-4 1.625 0.5 0 0 0</pose><geometry><box><size>0.2 2.25 1</size></box></geometry><material><ambient>1 0 0 1</ambient><diffuse>1 0 0 1</diffuse></material></visual>
        <collision name="cwv1a"><pose>-4 1.625 0.5 0 0 0</pose><geometry><box><size>0.2 2.25 1</size></box></geometry></collision>
        <!-- Door gap -->
        <visual name="wv1b"><pose>-4 5.875 0.5 0 0 0</pose><geometry><box><size>0.2 3.25 1</size></box></geometry><material><ambient>1 0 0 1</ambient><diffuse>1 0 0 1</diffuse></material></visual>
        <collision name="cwv1b"><pose>-4 5.875 0.5 0 0 0</pose><geometry><box><size>0.2 3.25 1</size></box></geometry></collision>

        <!-- Vertical wall at x=2: bedrooms | kitchen -->
        <visual name="wv2a"><pose>2 1.625 0.5 0 0 0</pose><geometry><box><size>0.2 2.25 1</size></box></geometry><material><ambient>1 0 0 1</ambient><diffuse>1 0 0 1</diffuse></material></visual>
        <collision name="cwv2a"><pose>2 1.625 0.5 0 0 0</pose><geometry><box><size>0.2 2.25 1</size></box></geometry></collision>
        <!-- Door gap -->
        <visual name="wv2b"><pose>2 5.875 0.5 0 0 0</pose><geometry><box><size>0.2 3.25 1</size></box></geometry><material><ambient>1 0 0 1</ambient><diffuse>1 0 0 1</diffuse></material></visual>
        <collision name="cwv2b"><pose>2 5.875 0.5 0 0 0</pose><geometry><box><size>0.2 3.25 1</size></box></geometry></collision>

        <!-- Vertical wall at x=2: living room | bath -->
        <visual name="wv3a"><pose>2 -5.375 0.5 0 0 0</pose><geometry><box><size>0.2 4.25 1</size></box></geometry><material><ambient>1 0 0 1</ambient><diffuse>1 0 0 1</diffuse></material></visual>
        <collision name="cwv3a"><pose>2 -5.375 0.5 0 0 0</pose><geometry><box><size>0.2 4.25 1</size></box></geometry></collision>
        <!-- Door gap -->
        <visual name="wv3b"><pose>2 -0.625 0.5 0 0 0</pose><geometry><box><size>0.2 2.25 1</size></box></geometry><material><ambient>1 0 0 1</ambient><diffuse>1 0 0 1</diffuse></material></visual>
        <collision name="cwv3b"><pose>2 -0.625 0.5 0 0 0</pose><geometry><box><size>0.2 2.25 1</size></box></geometry></collision>
      </link>
    </model>

    <model name="explorer_bot">
      <pose>-5 -3.5 0.2 0 0 1.5707</pose>
   <plugin filename="gz-sim-diff-drive-system" name="gz::sim::systems::DiffDrive">
        <left_joint>left_wheel_joint</left_joint>
        <right_joint>right_wheel_joint</right_joint>
        <wheel_separation>0.4</wheel_separation>
        <wheel_radius>0.1</wheel_radius>
        <topic>/cmd_vel</topic>
        <odom_publish_frequency>30</odom_publish_frequency>
        <odom_topic>/odom</odom_topic>
        <frame_id>odom</frame_id>
        <child_frame_id>base_link</child_frame_id>
        <tf_topic>/tf</tf_topic>
      </plugin>

      <link name="chassis">
        <inertial><mass>1.0</mass><inertia><ixx>0.01</ixx><ixy>0</ixy><ixz>0</ixz><iyy>0.01</iyy><iyz>0</iyz><izz>0.01</izz></inertia></inertial>
        <collision name="collision"><geometry><box><size>0.4 0.3 0.1</size></box></geometry></collision>
        <visual name="visual"><geometry><box><size>0.4 0.3 0.1</size></box></geometry><material><ambient>0 0 1 1</ambient><diffuse>0 0 1 1</diffuse></material></visual>

        <collision name="caster_collision">
          <pose>-0.15 0 -0.05 0 0 0</pose><geometry><sphere><radius>0.05</radius></sphere></geometry>
          <surface><friction><ode><mu>0.01</mu><mu2>0.01</mu2></ode></friction></surface>
        </collision>
        <visual name="caster_visual"><pose>-0.15 0 -0.05 0 0 0</pose><geometry><sphere><radius>0.05</radius></sphere></geometry><material><ambient>0 0 0 1</ambient><diffuse>0 0 0 1</diffuse></material></visual>

      <sensor name="lidar" type="gpu_lidar">
          <pose>0.21 0 0.3 0 0 0</pose>
          <topic>/scan</topic>
          <update_rate>10</update_rate>
          <gz_frame_id>lidar</gz_frame_id> <ray>
            <scan><horizontal><samples>360</samples><resolution>1</resolution><min_angle>-3.14</min_angle><max_angle>3.14</max_angle></horizontal></scan>
            <range><min>0.20</min><max>8.0</max></range>
          </ray>
          <always_on>1</always_on>
          <visualize>true</visualize>
        </sensor>
      </link>

      <link name="left_wheel">
        <pose>0.1 0.2 0 -1.5707 0 0</pose>
        <inertial><mass>0.2</mass><inertia><ixx>0.001</ixx><iyy>0.001</iyy><izz>0.001</izz></inertia></inertial>
        <collision name="collision"><geometry><cylinder><radius>0.1</radius><length>0.05</length></cylinder></geometry></collision>
        <visual name="visual"><geometry><cylinder><radius>0.1</radius><length>0.05</length></cylinder></geometry><material><ambient>0.2 0.2 0.2 1</ambient><diffuse>0.2 0.2 0.2 1</diffuse></material></visual>
      </link>

      <link name="right_wheel">
        <pose>0.1 -0.2 0 -1.5707 0 0</pose>
        <inertial><mass>0.2</mass><inertia><ixx>0.001</ixx><iyy>0.001</iyy><izz>0.001</izz></inertia></inertial>
        <collision name="collision"><geometry><cylinder><radius>0.1</radius><length>0.05</length></cylinder></geometry></collision>
        <visual name="visual"><geometry><cylinder><radius>0.1</radius><length>0.05</length></cylinder></geometry><material><ambient>0.2 0.2 0.2 1</ambient><diffuse>0.2 0.2 0.2 1</diffuse></material></visual>
      </link>

      <joint name="left_wheel_joint" type="revolute"><parent>chassis</parent><child>left_wheel</child><axis><xyz>0 0 1</xyz></axis></joint>
      <joint name="right_wheel_joint" type="revolute"><parent>chassis</parent><child>right_wheel</child><axis><xyz>0 0 1</xyz></axis></joint>
    </model>
  </world>
</sdf>
